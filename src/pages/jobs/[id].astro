---
import Layout from '../../layouts/Layout.astro';
import JobDetailView from '../../components/JobDetailView';
import { DEMO_JOBS } from '../../demo-data';
import { defaultConfig } from '../../config';

export async function getStaticPaths() {
  const config = defaultConfig;

  if (config.service.corpToken === 'demo') {
    return DEMO_JOBS.map(job => ({
      params: { id: String(job.id) },
      props: { job },
    }));
  }

  // Fetch all open jobs from Bullhorn
  const base = `https://public-rest${config.service.swimlane}.bullhornstaffing.com:443/rest-services/${config.service.corpToken}`;
  const url = `${base}/search/JobOrder?query=(isOpen:1)%20AND%20(isDeleted:0)&fields=${config.service.fields}&count=500&sort=-dateLastPublished&showTotalMatched=true`;
  const res = await fetch(url);
  const data = await res.json() as { data?: any[] };
  const jobs = data.data ?? [];

  return jobs.map((job: any) => ({
    params: { id: String(job.id) },
    props: {
      job: {
        ...job,
        address: {
          city: job.address?.city ?? '',
          state: job.address?.state ?? '',
          country: job.address?.countryName ?? 'US',
        },
        publishedCategory: job.publishedCategory ?? { id: 0, name: 'General' },
        salary: job.salary ? (job.salaryUnit ? `$${job.salary}/${job.salaryUnit}` : `$${job.salary.toLocaleString()}`) : '',
        benefits: '',
      },
    },
  }));
}

const { job } = Astro.props;
const title = `${job.title} | ${defaultConfig.companyName} Careers`;
const description = `${job.employmentType} position in ${job.address.state === 'Remote' ? 'Remote' : `${job.address.city}, ${job.address.state}`}${job.salary ? `. Salary: ${job.salary}` : ''}.`;

const jsonLd = {
  "@context": "https://schema.org/",
  "@type": "JobPosting",
  "title": job.title,
  "description": job.publicDescription,
  "datePosted": new Date(job.dateLastPublished).toISOString().split('T')[0],
  "employmentType": job.employmentType,
  "hiringOrganization": {
    "@type": "Organization",
    "name": defaultConfig.companyName,
    "sameAs": defaultConfig.companyUrl,
  },
  "jobLocation": job.address.state === 'Remote'
    ? { "@type": "Place", "address": { "@type": "PostalAddress", "addressCountry": "US" }, "name": "Remote" }
    : {
        "@type": "Place",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": job.address.city,
          "addressRegion": job.address.state,
          "addressCountry": job.address.country || "US",
        },
      },
  ...(job.salary
    ? {
        "baseSalary": {
          "@type": "MonetaryAmount",
          "currency": "USD",
          "value": {
            "@type": "QuantitativeValue",
            "value": job.salary,
          },
        },
      }
    : {}),
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <JobDetailView job={job} client:load />
</Layout>
