---
import LivePortal from '../components/LivePortal';
import { defaultConfig } from '../config';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Careers</title>
  <meta name="description" content="Browse open positions and find your next career opportunity." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <style define:vars={{ primaryColor: defaultConfig.primaryColor, accentColor: defaultConfig.accentColor }}>
    :root {
      --color-primary: var(--primaryColor);
      --color-accent: var(--accentColor);
    }
    body {
      font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    }
  </style>
</head>
<body class="bg-slate-50 min-h-screen">
  <LivePortal client:load />
</body>
</html>
