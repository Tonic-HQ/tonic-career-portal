---
import AdminPanel from '../components/AdminPanel';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Portal Admin — Tonic Career Portal</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root { --color-primary: #2563EB; --color-accent: #10B981; }
    body { font-family: 'Inter', system-ui, sans-serif; overflow: hidden; }
  </style>
</head>
<body class="bg-slate-50">
  <AdminPanel client:load />
</body>
</html>
