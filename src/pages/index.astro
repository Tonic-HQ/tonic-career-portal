---
// Landing page - product entry point for careersite.appsforstaffing.com
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tonic Career Portal - Modern Career Sites for Bullhorn</title>
  <meta name="description" content="Replace the Bullhorn OSCP with a modern, mobile-first career portal. Quick apply, LinkedIn integration, and real analytics - in minutes, not months." />
  <meta property="og:title" content="Tonic Career Portal" />
  <meta property="og:description" content="Modern career sites for Bullhorn. Quick apply, LinkedIn integration, real analytics." />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body class="bg-[#fafbfc] font-['Plus_Jakarta_Sans',system-ui,sans-serif] text-[#1a1a2e] antialiased">

  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-xl border-b border-gray-100">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center">
          <svg class="w-4.5 h-4.5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0" />
          </svg>
        </div>
        <span class="font-bold text-lg tracking-tight">Tonic Career Portal</span>
      </a>
      <div class="hidden sm:flex items-center gap-6 text-sm font-medium text-gray-500">
        <a href="/why" class="hover:text-gray-900 transition-colors">Why Us</a>
        <a href="/pricing" class="hover:text-gray-900 transition-colors">Pricing</a>
        <a href="/preview" class="px-4 py-2 rounded-lg bg-[#1a1a2e] text-white hover:bg-[#2d2d4e] transition-colors">Preview Your Site</a>
      </div>
      <a href="/preview" class="sm:hidden px-4 py-2 rounded-lg bg-[#1a1a2e] text-white text-sm font-medium">Preview</a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="pt-32 pb-20 px-6 relative overflow-hidden">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-to-b from-indigo-50/50 via-white to-transparent pointer-events-none"></div>
    <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-gradient-to-r from-indigo-200/30 to-violet-200/30 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-4xl mx-auto text-center relative">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-indigo-50 border border-indigo-100 text-indigo-600 text-xs font-semibold tracking-wide uppercase mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></span>
        Built for Bullhorn
      </div>

      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1.08] mb-6">
        Your career portal
        <br />
        <span class="bg-gradient-to-r from-indigo-600 to-violet-600 bg-clip-text text-transparent">deserves better</span>
      </h1>

      <p class="text-lg sm:text-xl text-gray-500 max-w-2xl mx-auto mb-10 leading-relaxed">
        The Bullhorn OSCP hasn't been updated in years. No quick apply, no mobile support, no analytics.
        We built the replacement - modern, fast, and ready in minutes.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/preview" class="group w-full sm:w-auto inline-flex items-center justify-center gap-2.5 px-8 py-4 rounded-xl bg-[#1a1a2e] text-white font-semibold text-base hover:bg-[#2d2d4e] hover:shadow-xl hover:shadow-indigo-500/10 active:scale-[0.98] transition-all">
          Preview Your Site
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a href="/site#config=eyJjb21wYW55TmFtZSI6IlRvbmljIEhRIiwiY29tcGFueVVybCI6Imh0dHBzOi8vdG9uaWNocS5jb20iLCJwcmltYXJ5Q29sb3IiOiIjNGY0NmU1IiwiYWNjZW50Q29sb3IiOiIjZWVmMmZmIiwiY29ycFRva2VuIjoiM2FwdzI5Iiwic3dpbWxhbmUiOiI5MSJ9" class="group w-full sm:w-auto inline-flex items-center justify-center gap-2.5 px-8 py-4 rounded-xl bg-white text-[#1a1a2e] font-semibold text-base border-2 border-[#1a1a2e]/15 hover:border-[#1a1a2e]/30 hover:shadow-xl hover:shadow-indigo-500/10 active:scale-[0.98] transition-all">
          View Demo
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="pb-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-3 gap-6">
        <!-- Quick Apply -->
        <div class="group p-8 rounded-2xl bg-white border border-gray-100 hover:border-indigo-100 hover:shadow-lg hover:shadow-indigo-500/5 transition-all">
          <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Quick Apply</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Name, email, done. No résumé required. The #1 feature missing from the OSCP - and the #1 reason candidates abandon applications.
          </p>
        </div>

        <!-- Mobile First -->
        <div class="group p-8 rounded-2xl bg-white border border-gray-100 hover:border-indigo-100 hover:shadow-lg hover:shadow-indigo-500/5 transition-all">
          <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Mobile-First</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            60%+ of job seekers search on mobile. The OSCP barely works on a phone. Ours is designed for thumbs first, desktops second.
          </p>
        </div>

        <!-- LinkedIn Integration -->
        <div class="group p-8 rounded-2xl bg-white border border-gray-100 hover:border-indigo-100 hover:shadow-lg hover:shadow-indigo-500/5 transition-all">
          <div class="w-12 h-12 rounded-xl bg-sky-50 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-[#0A66C2]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2">LinkedIn Sign-In</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            One tap to auto-fill name, email, and profile link. Candidates apply in seconds, recruiters get richer data.
          </p>
        </div>

        <!-- Source Attribution -->
        <div class="group p-8 rounded-2xl bg-white border border-gray-100 hover:border-indigo-100 hover:shadow-lg hover:shadow-indigo-500/5 transition-all">
          <div class="w-12 h-12 rounded-xl bg-amber-50 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Source Attribution</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Know exactly where every candidate came from - Google, LinkedIn, Indeed, email campaigns. Written directly to Bullhorn.
          </p>
        </div>

        <!-- OSCP Compatible -->
        <div class="group p-8 rounded-2xl bg-white border border-gray-100 hover:border-indigo-100 hover:shadow-lg hover:shadow-indigo-500/5 transition-all">
          <div class="w-12 h-12 rounded-xl bg-violet-50 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-violet-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Import in 30 Seconds</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Paste your OSCP URL - we pull your config, colors, and branding automatically. See your new portal before you buy it.
          </p>
        </div>

        <!-- Pricing -->
        <div class="group p-8 rounded-2xl bg-white border border-gray-100 hover:border-indigo-100 hover:shadow-lg hover:shadow-indigo-500/5 transition-all">
          <div class="w-12 h-12 rounded-xl bg-rose-50 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-rose-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Starts at $199</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            One-time purchase for static files you own forever. Or $499/yr with LinkedIn sign-in, email alerts, and managed hosting. <a href="/pricing" class="text-indigo-600 hover:text-indigo-700 font-medium">See all plans</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="pb-24 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="relative rounded-3xl bg-gradient-to-br from-[#1a1a2e] to-[#2d2d5e] p-12 sm:p-16 text-center overflow-hidden">
        <!-- Decorative gradient blobs -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-indigo-500/20 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-violet-500/20 rounded-full blur-3xl pointer-events-none"></div>

        <div class="relative">
          <h2 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight mb-4">
            See your portal in 30 seconds
          </h2>
          <p class="text-indigo-200 text-lg mb-8 max-w-xl mx-auto">
            Paste your current OSCP URL. We'll import your config, match your branding, and show you what your career site could look like - no signup required.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="/preview" class="w-full sm:w-auto inline-flex items-center justify-center gap-2.5 px-8 py-4 rounded-xl bg-white text-[#1a1a2e] font-bold text-base hover:bg-indigo-50 active:scale-[0.98] transition-all shadow-lg shadow-black/20">
              Preview Your Site
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a href="/why" class="text-indigo-300 hover:text-white font-medium text-sm transition-colors">
              Read why we built this →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-gray-100 py-8 px-6">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-400">
      <span>© 2026 Tonic HQ. Part of the <a href="https://appsforstaffing.com" class="text-gray-500 hover:text-gray-700 transition-colors">Apps for Staffing</a> suite.</span>
      <div class="flex items-center gap-6">
        <a href="/preview" class="hover:text-gray-600 transition-colors">Preview</a>
        <a href="/pricing" class="hover:text-gray-600 transition-colors">Pricing</a>
        <a href="/why" class="hover:text-gray-600 transition-colors">Why Us</a>
      </div>
    </div>
  </footer>

</body>
</html>
