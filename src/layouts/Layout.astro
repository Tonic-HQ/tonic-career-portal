---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { defaultConfig } from '../config';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  embed?: boolean;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title = defaultConfig.companyName + ' Careers',
  description = 'Browse open positions at ' + defaultConfig.companyName,
  embed = false,
  ogImage,
  noIndex = false,
} = Astro.props;

const isEmbed = embed || Astro.url.searchParams.get('embed') === 'true';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noIndex && <meta name="robots" content="noindex,nofollow" />}
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <style define:vars={{ primaryColor: defaultConfig.primaryColor, accentColor: defaultConfig.accentColor }}>
    :root {
      --color-primary: var(--primaryColor);
      --color-accent: var(--accentColor);
    }
    body {
      font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    }
  </style>
</head>
<body class={isEmbed ? 'bg-transparent' : 'bg-slate-50 min-h-screen flex flex-col'}>
  {!isEmbed && <Header />}
  <main class={isEmbed ? '' : 'flex-1 w-full'}>
    <slot />
  </main>
  {!isEmbed && <Footer />}
  <script>
    // Listen for real-time config updates from the Admin panel (postMessage)
    window.addEventListener('message', (event) => {
      if (!event.data || event.data.type !== 'TONIC_CONFIG_UPDATE') return;
      const cfg = event.data.config;
      if (!cfg) return;
      const root = document.documentElement;
      if (cfg.primaryColor) root.style.setProperty('--color-primary', cfg.primaryColor);
      if (cfg.accentColor) root.style.setProperty('--color-accent', cfg.accentColor);
      if (cfg.backgroundColor) document.body.style.backgroundColor = cfg.backgroundColor;
      if (cfg.textColor) root.style.setProperty('--color-text', cfg.textColor);
      if (cfg.primaryFont && cfg.primaryFont !== 'Same as primary') {
        document.body.style.fontFamily = `'${cfg.primaryFont}', system-ui, sans-serif`;
        const fontId = `gfont-${cfg.primaryFont.replace(/\s/g, '-')}`;
        if (!document.getElementById(fontId)) {
          const link = document.createElement('link');
          link.id = fontId;
          link.rel = 'stylesheet';
          link.href = `https://fonts.googleapis.com/css2?family=${encodeURIComponent(cfg.primaryFont)}:wght@300;400;500;600;700&display=swap`;
          document.head.appendChild(link);
        }
      }
    });
  </script>
</body>
</html>
