---
import { defaultConfig } from '../config';

const currentYear = new Date().getFullYear();
---

<footer class="bg-white border-t border-gray-100 mt-auto">
  <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
    <p class="text-sm text-gray-400">
      &copy; {currentYear} {defaultConfig.companyName}. All rights reserved.
    </p>
    <div class="flex items-center gap-4">
      {defaultConfig.privacyPolicyUrl && (
        <a
          href={defaultConfig.privacyPolicyUrl}
          class="text-sm text-gray-400 hover:text-gray-600 transition-colors"
        >
          Privacy Policy
        </a>
      )}
      <span class="text-sm text-gray-300">
        Powered by{' '}
        <a
          href="https://tonichq.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-400 hover:text-gray-600 transition-colors"
        >
          Tonic Career Portal
        </a>
      </span>
    </div>
  </div>
</footer>
