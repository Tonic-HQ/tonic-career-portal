---
interface Props {
  active?: 'home' | 'why' | 'pricing' | 'preview' | 'admin';
}

const { active } = Astro.props;

function linkClass(page: string): string {
  return page === active
    ? 'text-gray-900'
    : 'hover:text-gray-900 transition-colors';
}
---

<nav class="sticky top-0 w-full z-[60] bg-white/80 backdrop-blur-xl border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center">
        <svg class="w-4.5 h-4.5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0" />
        </svg>
      </div>
      <span class="font-bold text-lg tracking-tight">Tonic Career Portal</span>
    </a>
    <div class="hidden sm:flex items-center gap-6 text-sm font-medium text-gray-500">
      <a href="/why" class={linkClass('why')}>Why Us</a>
      <a href="/pricing" class={linkClass('pricing')}>Pricing</a>
      <a href="/admin" class={linkClass('admin')}>Sign In</a>
      <a href="/preview" class="px-4 py-2 rounded-lg bg-[#1a1a2e] text-white hover:bg-[#2d2d4e] transition-colors">Preview Your Site</a>
    </div>
    <a href="/preview" class="sm:hidden px-4 py-2 rounded-lg bg-[#1a1a2e] text-white text-sm font-medium">Preview</a>
  </div>
</nav>
