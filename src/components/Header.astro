---
import { defaultConfig } from '../config';
---

<header class="bg-white/95 backdrop-blur-sm border-b border-gray-100 sticky top-0 z-40" style="box-shadow: 0 1px 3px 0 rgba(0,0,0,0.05), 0 1px 2px -1px rgba(0,0,0,0.04);">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      {defaultConfig.companyLogoUrl ? (
        <img
          src={defaultConfig.companyLogoUrl}
          alt={defaultConfig.companyName + ' logo'}
          class="h-8 w-auto"
        />
      ) : (
        <div class="flex items-center gap-2.5">
          <div
            class="w-9 h-9 rounded-xl flex items-center justify-center shadow-sm transition-all duration-200 group-hover:scale-105 group-hover:shadow-md"
            style={`background: linear-gradient(135deg, ${defaultConfig.primaryColor} 0%, #1d4ed8 100%)`}
          >
            <svg class="w-[18px] h-[18px] text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" />
            </svg>
          </div>
          <div class="flex flex-col leading-none">
            <span class="font-bold text-gray-900 text-[15px] tracking-tight transition-colors group-hover:text-blue-600">
              {defaultConfig.companyName}
            </span>
            <span class="text-[9px] font-semibold text-gray-400 tracking-[0.12em] uppercase mt-0.5">
              Careers
            </span>
          </div>
        </div>
      )}
    </a>

    <nav class="flex items-center gap-1">
      <a
        href="/"
        class="text-sm font-medium text-gray-500 hover:text-blue-600 px-3 py-2 rounded-lg transition-all hover:bg-blue-50"
      >
        All Jobs
      </a>
      {defaultConfig.companyUrl && (
        <a
          href={defaultConfig.companyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium text-gray-500 hover:text-blue-600 px-3 py-2 rounded-lg transition-all hover:bg-blue-50 inline-flex items-center gap-1.5"
        >
          Company Site
          <svg class="w-3 h-3 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      )}
    </nav>
  </div>
</header>
