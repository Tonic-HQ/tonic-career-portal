---
import { defaultConfig } from '../config';
---

<header class="bg-white border-b border-gray-100 sticky top-0 z-40">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      {defaultConfig.companyLogoUrl ? (
        <img
          src={defaultConfig.companyLogoUrl}
          alt={defaultConfig.companyName + ' logo'}
          class="h-8 w-auto"
        />
      ) : (
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center" style={`background-color: ${defaultConfig.primaryColor}`}>
            <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" />
            </svg>
          </div>
          <span class="font-semibold text-gray-900 text-lg group-hover:text-blue-600 transition-colors">
            {defaultConfig.companyName}
          </span>
        </div>
      )}
    </a>

    <nav class="flex items-center gap-1">
      <a
        href="/"
        class="text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-lg transition-colors"
      >
        All Jobs
      </a>
      {defaultConfig.companyUrl && (
        <a
          href={defaultConfig.companyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-lg transition-colors inline-flex items-center gap-1"
        >
          Company Site
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      )}
    </nav>
  </div>
</header>
